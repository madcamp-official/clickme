# Production runtime template.
# Store real values only in .env.local (local) or
# /srv/clickme/shared/clickme.env (KAIST server, mode 600).
NODE_ENV=production
PORT=3001
# Shared by both deployment methods: systemd overrides this to 127.0.0.1 in
# ExecStart; Compose publishes the container port to host loopback only.
HOSTNAME=0.0.0.0
NEXT_PUBLIC_SITE_URL=https://clickme.madcamp-kaist.org
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=replace-with-server-secret
# Generate once with strong randomness and keep it stable across releases.
# Rotating it disconnects existing visitor cookies from their votes.
VISITOR_HASH_SECRET=replace-with-at-least-32-random-bytes

# Migration-only local variable. Never copy it to clickme.env.
# SUPABASE_DB_URL=postgresql://user:percent-encoded-password@host:5432/database
