generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum PostStatus {
  OPEN
  CLOSED
}

enum ParticipationStatus {
  CONFIRMED
  CANCELLED
}

enum PurchaseRequestStatus {
  OPEN
  ACCEPTED
  CANCELLED
}

enum NotificationType {
  PURCHASE_REQUEST_ACCEPTED
  PARTICIPATION_CREATED
}

enum MenuCategory {
  DRINK
  FOOD
  PRODUCT
}

enum MenuAvailability {
  AVAILABLE
  UNAVAILABLE
  UNKNOWN
}

enum InquiryCategory {
  SERVICE
  ACCOUNT
  MODERATION
  PAYMENT
  OTHER
}

enum InquiryStatus {
  PENDING
  RESOLVED
}

enum ReportReason {
  FRAUD
  NO_SHOW
  ABUSE
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED
  REJECTED
}

model User {
  id                 String            @id @default(cuid())
  kakaoUserId        String            @unique @db.VarChar(32)
  nickname           String            @unique @db.VarChar(20)
  profileImage       String?
  role               UserRole          @default(USER)
  status             UserStatus        @default(ACTIVE)
  rating             Float             @default(0)
  reviewCount        Int               @default(0)
  lastLoginAt        DateTime          @default(now())
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  suspendedAt        DateTime?
  suspensionReason   String?
  deletedAt          DateTime?
  sessions           AuthSession[]
  posts              Post[]            @relation("PostWriter")
  writtenReviews     Review[]          @relation("ReviewWriter")
  receivedReviews    Review[]          @relation("ReviewSeller")
  favorites          Favorite[]
  participations     Participation[]
  purchaseRequests   PurchaseRequest[] @relation("PurchaseRequestRequester")
  acceptedRequests   PurchaseRequest[] @relation("PurchaseRequestAccepter")
  inquiries          Inquiry[]
  reports            Report[]          @relation("ReportReporter")
  handledReports     Report[]          @relation("ReportHandler")
  adminActions       AdminActionLog[]  @relation("AdminActions")
  verifiedStoreMenus StoreMenu[]       @relation("StoreMenuVerifier")
  notifications      Notification[]    @relation("NotificationRecipient")
  notificationEvents Notification[]    @relation("NotificationActor")

  @@index([status])
  @@index([createdAt])
}

model AuthSession {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @unique @db.Char(64)
  expiresAt        DateTime
  revokedAt        DateTime?
  lastUsedAt       DateTime?
  userAgent        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Store {
  id               String            @id @default(cuid())
  brand            String            @default("메가MGC커피")
  name             String
  region           String
  district         String?
  address          String
  phone            String?
  latitude         Decimal?          @db.Decimal(9, 6)
  longitude        Decimal?          @db.Decimal(9, 6)
  source           String            @default("MANUAL")
  externalId       String?           @unique
  sourceUrl        String?
  isActive         Boolean           @default(true)
  lastSyncedAt     DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  posts            Post[]
  storeMenus       StoreMenu[]
  purchaseRequests PurchaseRequest[]
  participationPickups Participation[]

  @@unique([name, address])
  @@index([name])
  @@index([region])
  @@index([district])
  @@index([isActive, region, name])
}

model Menu {
  id               String            @id @default(cuid())
  externalId       String            @unique
  brand            String            @default("메가MGC커피")
  name             String
  englishName      String?
  category         MenuCategory
  variant          String            @default("NONE")
  description      String?
  imageUrl         String?
  source           String            @default("MANUAL")
  sourceUrl        String?
  isActive         Boolean           @default(true)
  lastSyncedAt     DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  storeMenus       StoreMenu[]
  purchaseRequests PurchaseRequest[]
  participations   Participation[]

  @@unique([brand, category, name, variant])
  @@index([isActive, category, name])
  @@index([name])
}

model StoreMenu {
  storeId      String
  menuId       String
  availability MenuAvailability @default(AVAILABLE)
  verifiedById String?
  verifiedAt   DateTime         @default(now())
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  store        Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  menu         Menu             @relation(fields: [menuId], references: [id], onDelete: Cascade)
  verifiedBy   User?            @relation("StoreMenuVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@id([storeId, menuId])
  @@index([menuId, availability])
  @@index([storeId, availability])
  @@index([verifiedById])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  bannerImage String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       Post[]

  @@index([isActive, startDate, endDate])
}

model Post {
  id             String          @id @default(cuid())
  writerId       String
  storeId        String
  eventId        String?
  discount       Int
  totalCount     Int
  remainCount    Int
  meetingTime    DateTime
  availableUntil DateTime?
  meetingPlace   String
  openChatUrl    String
  description    String?
  imageUrl       String?
  status         PostStatus      @default(OPEN)
  closedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  writer         User            @relation("PostWriter", fields: [writerId], references: [id], onDelete: Restrict)
  store          Store           @relation(fields: [storeId], references: [id], onDelete: Restrict)
  event          Event?          @relation(fields: [eventId], references: [id], onDelete: SetNull)
  reviews        Review[]
  favorites      Favorite[]
  reports        Report[]
  participations Participation[]

  @@index([status])
  @@index([createdAt])
  @@index([discount])
  @@index([remainCount])
  @@index([meetingTime])
  @@index([writerId])
  @@index([storeId])
  @@index([eventId])
  @@index([deletedAt, status, createdAt])
}

model Participation {
  id             String              @id @default(cuid())
  userId         String
  postId         String
  pickupStoreId  String?
  menuId         String?
  quantity       Int
  pickupStore    String
  menu           String?
  status         ParticipationStatus @default(CONFIRMED)
  cancelledAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  post           Post                @relation(fields: [postId], references: [id], onDelete: Restrict)
  pickupStoreRef Store?              @relation(fields: [pickupStoreId], references: [id], onDelete: SetNull)
  selectedMenu   Menu?               @relation(fields: [menuId], references: [id], onDelete: SetNull)

  @@unique([userId, postId])
  @@index([postId, status])
  @@index([userId, createdAt])
  @@index([pickupStoreId])
  @@index([menuId])
}

model PurchaseRequest {
  id           String                @id @default(cuid())
  requesterId  String
  accepterId   String?
  storeId      String?
  menuId       String?
  city         String
  branch       String
  menu         String
  quantity     Int
  desiredTime  String
  note         String?
  openChatUrl  String
  status       PurchaseRequestStatus @default(OPEN)
  acceptedAt   DateTime?
  cancelledAt  DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  requester    User                  @relation("PurchaseRequestRequester", fields: [requesterId], references: [id], onDelete: Restrict)
  accepter     User?                 @relation("PurchaseRequestAccepter", fields: [accepterId], references: [id], onDelete: SetNull)
  store        Store?                @relation(fields: [storeId], references: [id], onDelete: SetNull)
  selectedMenu Menu?                 @relation(fields: [menuId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([requesterId, createdAt])
  @@index([accepterId, createdAt])
  @@index([storeId])
  @@index([menuId])
}

model Notification {
  id           String           @id @default(cuid())
  recipientId  String
  actorId      String?
  type         NotificationType
  title        String
  message      String
  resourceType String
  resourceId   String
  readAt       DateTime?
  createdAt    DateTime         @default(now())
  recipient    User             @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor        User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([recipientId, createdAt])
  @@index([recipientId, readAt, createdAt])
  @@index([resourceType, resourceId])
  @@index([actorId])
}

model Inquiry {
  id        String          @id @default(cuid())
  userId    String
  category  InquiryCategory
  content   String
  status    InquiryStatus   @default(PENDING)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model Review {
  id        String   @id @default(cuid())
  writerId  String
  sellerId  String
  postId    String
  rating    Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  writer    User     @relation("ReviewWriter", fields: [writerId], references: [id], onDelete: Restrict)
  seller    User     @relation("ReviewSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Restrict)

  @@unique([writerId, postId])
  @@index([sellerId, createdAt])
  @@index([postId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model Report {
  id           String       @id @default(cuid())
  reporterId   String
  targetPostId String
  reason       ReportReason
  detail       String?
  status       ReportStatus @default(PENDING)
  handledById  String?
  adminNote    String?
  handledAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  reporter     User         @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  targetPost   Post         @relation(fields: [targetPostId], references: [id], onDelete: Restrict)
  handledBy    User?        @relation("ReportHandler", fields: [handledById], references: [id], onDelete: SetNull)

  @@unique([reporterId, targetPostId, reason])
  @@index([status, createdAt])
  @@index([targetPostId])
  @@index([handledById])
}

model AdminActionLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  reason     String?
  metadata   Json?
  createdAt  DateTime @default(now())
  admin      User     @relation("AdminActions", fields: [adminId], references: [id], onDelete: Restrict)

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
}
